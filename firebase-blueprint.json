{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "username": { "type": "string" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "username"]
    },
    "Post": {
      "title": "Post",
      "description": "Social media post.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "likes": { "type": "number" },
        "comments": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Public social posts."
    },
    "/posts/{postId}/likes/{userId}": {
      "schema": { "type": "object", "properties": { "at": { "type": "string", "format": "date-time" } } },
      "description": "Likes on a post."
    }
  }
}
